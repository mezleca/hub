<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>elter-hub</title>
    <link rel="stylesheet" href="styles/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <div class="container">
        <!-- inicio -->
        <div class="navbar">
            <div class="logo">
                <h1><a href="/media" style="color: white;">ELTER-HUB</a></h1>
            </div>
        </div>

        <nav class="menu">
            <div class="resto">
                <div class="icons">
                    <div id="img1" class="bi bi-house" style="color: white;"></div>
                    <div id="img2" class="bi bi-images" style="color: white;"></div> 
                </div>

                <div class="texts" style="display: none;">
                    <div class="texto"><a href="/" id="txt1" style="color: white; font-size: 16px; font-weight: bold;">HOME</a></div>
                    <div class="texto"><a href="/media" id="txt2" style="color: white; font-size: 16px; font-weight: bold;">MEDIA</a></div>
                </div>    
            </div>
        </nav>

        <!-- conteudo -->
        <div class="form">
            <form action="/api/" method="post" enctype="multipart/form-data">

                <div class="formgrp">
                    <input type="text" name="name" id="name" placeholder="File name" required>
                    <label for="name" class="formlabel" class="arqv">Nome do arquivo</label>
                </div>

                <label for="file-input" class="label-file"> Escolha um arquivo </label>

                <input type="file" id="file-input" class="input-file" name="file">
                <span class="file-text">Nenhum arquivo selecionado</span>
                <button class="submit-button" type="submit">Enviar</button>
            </form>
        </div>

    </div>

    <script src="js/bonito.js"></script>
    <script src="js/change-icons.js"></script>
</body>
 
</html>