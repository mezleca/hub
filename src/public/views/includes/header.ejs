<div class="header"> 
    <div class="navbar">
        <div class="logo center-itens">
            <h1 style="text-wrap: nowrap;"><img src="/api/get_file/imgs/mini" id="logo_index" alt=""></h1>
        </div>
        <div class="search-container center-itens">
            <div class="search-input">
                <input type="text" id="search" placeholder="Pesquisar...">
                <div class="search-icon">
                    <i class="bi bi-search" style="font-size: 24px;" type="submit"></i>
                </div>
            </div>
        </div>
        <div class="auth-container">
            <% if (!user.name) { %>
                <div class="auth-buttons">
                    <button><a href="/auth/login">login</a></button>
                    <button><a href="/auth/register">register</a></button>
                </div>
            <% } else { %>
                <div class="auth-text">
                    <div style="color: white; display: inline-flex; align-items: center;"><a href="/profile/<%- user.name %>" style="font-size: 2.3em; font-weight: bold;" id="user_name"><%- user.name %></a> <p id="popup-menu" style="cursor: pointer; font-size: 20px; margin-left: 10px;"> ▼</p></div>
                </div>            
            <% } %>            
        </div>
    </div>
</div>
<div class="menu-popup" style="display: none;">
    <div class="menu-popup-itens">
        <div class="menu-popup-item">
            <div class="bi bi-house-fill" style="color: white;"></div>
            <h2><a href="/media">inicio</a></h2>
        </div>

        <div class="menu-popup-item">
            <div class="bi bi-upload" style="color: white;"></div>
            <h2><a href="/media/upload">upload</a></h2>
        </div>

        <div class="menu-popup-item">
            <div class="bi bi-person-fill" style="color: white;"></div>
            <h2><a href="/profile/<%- user.name %>">perfil</a></h2>
        </div>

        <div class="menu-popup-item">
            <div class="bi bi-trash-fill" style="color: white;"></div>
            <h2><a href="/api/clear">limpar</a></h2>
        </div>
    </div>
</div>